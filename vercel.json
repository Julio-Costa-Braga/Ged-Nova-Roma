{
  "version": 2,
  "builds": [
    {
      "src": "server-vercel.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/NOVAROMA/api/(.*)",
      "dest": "https://ged-nova-roma-backend.onrender.com/NOVAROMA/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "server-vercel.js"
    }
  ]
}
