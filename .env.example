# ============================================
# Supabase — GED Faculdade Nova Roma
# ============================================
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_sua-chave-secreta-aqui   # nunca expor no cliente

# ============================================
# JWT — gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================
JWT_SECRET=troque-por-uma-string-aleatoria-de-64-bytes-minimo

# ============================================
# CORS — origens permitidas (separadas por vírgula)
# ============================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,https://gednovaroma.docflow.dev.br

# ============================================
# Servidor
# ============================================
PORT=3000
BASE_PATH=NOVAROMA

# ============================================
# E-mail (envio de contratos) — opcional
# ============================================
MAIL_PROVIDER=resend
MAIL_API_KEY=sua-chave-api-aqui
MAIL_FROM=noreply@novaroma.com.br
